{
  "title": "RAG Platform",
  "uid": "rag-platform",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(rag_requests_total[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(rag_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (non-2xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_requests_total{status!~\"2..\"}[5m]))",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Guardrail blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "sum by (guardrail) (rate(rag_guardrail_blocks_total[5m]))",
          "legendFormat": "{{guardrail}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Self-correction rounds (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rate(rag_correction_rounds_sum[10m]) / rate(rag_correction_rounds_count[10m])",
          "legendFormat": "avg rounds"
        }
      ]
    },
    {
      "id": 6,
      "title": "Documents ingested",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (status) (increase(rag_documents_ingested_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Chunks per retrieval (p50)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum by (le) (rate(rag_retrieval_chunks_bucket[10m])))",
          "legendFormat": "p50 chunks"
        }
      ]
    }
  ]
}
